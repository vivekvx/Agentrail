# development | production. In production a real SECRET_KEY is required.
ENV=development

# SQLite for dev (default), Postgres for production
DATABASE_URL=sqlite:///./agentrail.db

# Auth — REQUIRED in production. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-only-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
