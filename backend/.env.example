# Postgres (default for production)
DATABASE_URL=postgresql+psycopg2://agentrail:agentrail@localhost:5432/agentrail
# SQLite fallback for local dev (no Postgres needed)
# DATABASE_URL=sqlite:///./agentrail.db

# LLM provider (OpenAI-compatible). For OpenRouter:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_API_KEY=sk-or-...
#   OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
LLM_ROOT_CAUSE_ENABLED=false
LLM_FIX_STRATEGY_ENABLED=false
LLM_TIMEOUT_SECONDS=30
REPO_WORKSPACE_DIR=./data/repos
GITHUB_IMPORT_ENABLED=true
GITHUB_ISSUE_IMPORT_ENABLED=true
GITHUB_API_TIMEOUT_SECONDS=30
GIT_CLONE_TIMEOUT_SECONDS=60
MAX_REPO_SIZE_MB=100
GITHUB_TOKEN=
MAX_ISSUE_BODY_CHARS=12000
E2B_ENABLED=false
E2B_API_KEY=
E2B_TEMPLATE=
E2B_TIMEOUT_SECONDS=120
E2B_RUN_TESTS_AFTER_APPROVAL=false
SANDBOX_RUNNER_PROVIDER=local
MAX_SANDBOX_UPLOAD_MB=50

# Auth — REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-only-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
